# --- CONFIGURAZIONE DATABASE POSTGRES ---
DB_NAME=playnode_db
DB_USER=playnode_admin
DB_HOST=playnode_postgres
DB_INTERNAL_PORT=5432
DB_PASSWORD=inserisci_qui_la_tua_password_locale
DB_PORT=5432

# --- CONFIGURAZIONE MQTT (MOSQUITTO) ---
MQTT_PORT=1883
MQTT_WS_PORT=9001
MQTT_USER=inserisci_qui_il_tuo_username_mqtt
MQTT_PASSWORD=inserisci_qui_la_tua_password_mqtt

# --- SICUREZZA E JWT ---
# Chiave segreta per la firma dei Token JWT (deve superare i 256 bit)
JWT_SECRET=inserisci_qui_la_tua_chiave_segreta_lunghissima

# Tempo di scadenza del token in millisecondi (1 ora)
JWT_EXPIRATION=3600000

# --- CORS ---
# Indirizzi autorizzati
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:63342,http://localhost:5173,http://localhost:4200,http://127.0.0.1:5500