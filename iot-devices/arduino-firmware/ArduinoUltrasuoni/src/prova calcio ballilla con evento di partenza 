// ══════════════════════════════════════════════════════════════════
//  PROTOTIPI
// ══════════════════════════════════════════════════════════════════
float measureCm(uint8_t trigPin, uint8_t echoPin);
void  registraGol(char team);
void  mqttCallback(char* topic, byte* payload, unsigned int length);
bool  mqttConnect();

void drawScoreboard();
